{
  "id": "mode-failover",
  "description": "Flexible model selection with random, weighted, and smart failover modes",
  "version": "1.0.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true
      },
      "mode": {
        "type": "string",
        "enum": [
          "random",
          "round-robin",
          "weighted",
          "smart"
        ],
        "default": "weighted",
        "description": "Model selection strategy"
      },
      "models": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": [
            "ref"
          ],
          "properties": {
            "ref": {
              "type": "string",
              "description": "Model reference in format provider/model"
            },
            "weight": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "default": 50,
              "description": "Selection weight (higher = more likely)"
            },
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Whether this model is available for selection"
            }
          }
        }
      },
      "stickiness": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false,
            "description": "Keep using the same model within a session"
          },
          "ttlMinutes": {
            "type": "number",
            "minimum": 0,
            "maximum": 1440,
            "default": 10,
            "description": "Stickiness expiration time in minutes"
          },
          "maxSessionModels": {
            "type": "number",
            "minimum": 1,
            "maximum": 10,
            "default": 1,
            "description": "Max models per session"
          }
        }
      },
      "failover": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "Enable automatic failover on errors"
          },
          "errorThreshold": {
            "type": "number",
            "minimum": 1,
            "maximum": 100,
            "default": 1,
            "description": "Consecutive errors before marking unhealthy"
          },
          "errorWindowMinutes": {
            "type": "number",
            "minimum": 1,
            "maximum": 60,
            "default": 5,
            "description": "Error counting window in minutes"
          },
          "cooldownMinutes": {
            "type": "number",
            "minimum": 1,
            "maximum": 1440,
            "default": 30,
            "description": "Cooldown period for unhealthy models"
          },
          "recoveryProbeInterval": {
            "type": "number",
            "minimum": 1,
            "maximum": 60,
            "default": 5,
            "description": "Recovery probe interval in minutes"
          },
          "timeoutMs": {
            "type": "number",
            "minimum": 5000,
            "maximum": 300000,
            "default": 30000,
            "description": "Request timeout threshold in milliseconds"
          }
        }
      },
      "stats": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "Enable statistics collection"
          },
          "persistInterval": {
            "type": "number",
            "minimum": 10000,
            "maximum": 300000,
            "default": 60000,
            "description": "Stats persistence interval in ms"
          },
          "maxHistoryHours": {
            "type": "number",
            "minimum": 1,
            "maximum": 168,
            "default": 24,
            "description": "History retention in hours"
          }
        }
      },
      "agents": {
        "type": "object",
        "description": "Per-agent configuration overrides",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Enable/disable plugin for this agent"
            },
            "config": {
              "type": "object",
              "description": "Agent-specific configuration (merges with global config)",
              "properties": {
                "mode": {
                  "type": "string",
                  "enum": [
                    "random",
                    "round-robin",
                    "weighted",
                    "smart"
                  ],
                  "description": "Model selection strategy for this agent"
                },
                "models": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "required": [
                      "ref"
                    ],
                    "properties": {
                      "ref": {
                        "type": "string",
                        "description": "Model reference in format provider/model"
                      },
                      "weight": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 100,
                        "default": 50,
                        "description": "Selection weight"
                      },
                      "enabled": {
                        "type": "boolean",
                        "default": true,
                        "description": "Whether this model is available"
                      }
                    }
                  }
                },
                "stickiness": {
                  "type": "object",
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "default": true
                    },
                    "ttlMinutes": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1440,
                      "default": 60
                    },
                    "maxSessionModels": {
                      "type": "number",
                      "minimum": 1,
                      "maximum": 10,
                      "default": 1
                    }
                  }
                },
                "failover": {
                  "type": "object",
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "default": true
                    },
                    "errorThreshold": {
                      "type": "number",
                      "minimum": 1,
                      "maximum": 100,
                      "default": 3
                    },
                    "errorWindowMinutes": {
                      "type": "number",
                      "minimum": 1,
                      "maximum": 60,
                      "default": 5
                    },
                    "cooldownMinutes": {
                      "type": "number",
                      "minimum": 1,
                      "maximum": 1440,
                      "default": 30
                    },
                    "recoveryProbeInterval": {
                      "type": "number",
                      "minimum": 1,
                      "maximum": 60,
                      "default": 5
                    }
                  }
                },
                "stats": {
                  "type": "object",
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "default": true
                    },
                    "persistInterval": {
                      "type": "number",
                      "minimum": 10000,
                      "maximum": 300000,
                      "default": 60000
                    },
                    "maxHistoryHours": {
                      "type": "number",
                      "minimum": 1,
                      "maximum": 168,
                      "default": 24
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "required": [
      "models"
    ]
  },
  "uiHints": {
    "mode": {
      "label": "Selection Mode",
      "help": "How to select models: random, round-robin, weighted, or smart"
    },
    "models": {
      "label": "Model Pool",
      "help": "List of models to select from"
    },
    "models[].ref": {
      "label": "Model Reference",
      "placeholder": "zai/glm-5"
    },
    "models[].weight": {
      "label": "Weight",
      "help": "Selection weight (0-100). Higher = more likely to be selected"
    },
    "models[].enabled": {
      "label": "Enabled",
      "help": "Whether this model is available for selection"
    },
    "stickiness.enabled": {
      "label": "Session Stickiness",
      "help": "Keep using the same model within a session"
    },
    "stickiness.ttlMinutes": {
      "label": "Stickiness TTL (minutes)",
      "advanced": true
    },
    "stickiness.maxSessionModels": {
      "label": "Max Models Per Session",
      "advanced": true
    },
    "failover.enabled": {
      "label": "Auto Failover",
      "help": "Automatically switch to healthy models on failure"
    },
    "failover.errorThreshold": {
      "label": "Error Threshold",
      "advanced": true,
      "help": "Consecutive errors before marking model unhealthy"
    },
    "failover.errorWindowMinutes": {
      "label": "Error Window (minutes)",
      "advanced": true
    },
    "failover.cooldownMinutes": {
      "label": "Cooldown Period (minutes)",
      "advanced": true,
      "help": "Time before retrying an unhealthy model"
    },
    "failover.recoveryProbeInterval": {
      "label": "Recovery Probe Interval (minutes)",
      "advanced": true
    },
    "stats.enabled": {
      "label": "Statistics Collection",
      "help": "Track model usage and performance"
    },
    "stats.persistInterval": {
      "label": "Stats Persist Interval (ms)",
      "advanced": true
    },
    "stats.maxHistoryHours": {
      "label": "History Retention (hours)",
      "advanced": true
    },
    "agents": {
      "label": "Agent-Specific Configuration",
      "help": "Override global config for specific agents"
    }
  }
}
